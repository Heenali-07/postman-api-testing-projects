    {
      "name": "10 API Chaining",
      "item": [
        {
          "name": "Step 1 - Get User And Save User Id",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const user = pm.response.json();",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.environment.set('chainedUserId', user.id);",
                  "",
                  "pm.test('User id saved for next request', function () {",
                  "    pm.expect(pm.environment.get('chainedUserId')).to.eql(String(user.id));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{jsonPlaceholderBaseUrl}}/users/1"
          },
          "response": []
        },
        {
          "name": "Step 2 - Use Saved User Id To Get Posts",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const posts = pm.response.json();",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Posts belong to saved user id', function () {",
                  "    posts.forEach(function (post) {",
                  "        pm.expect(post.userId).to.eql(Number(pm.environment.get('chainedUserId')));",
                  "    });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{jsonPlaceholderBaseUrl}}/posts?userId={{chainedUserId}}",
              "host": [
                "{{jsonPlaceholderBaseUrl}}"
              ],
              "path": [
                "posts"
              ],
              "query": [
                {
                  "key": "userId",
                  "value": "{{chainedUserId}}"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
