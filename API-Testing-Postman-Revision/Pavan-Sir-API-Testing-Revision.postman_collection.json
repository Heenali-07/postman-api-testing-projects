      "name": "13 XML and SOAP Basics",
      "item": [
        {
          "name": "POST XML Body To Echo API",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Raw XML body is sent', function () {",
                  "    pm.expect(response.data).to.include('<student>');",
                  "    pm.expect(response.data).to.include('<topic>XML Basics</topic>');",
                  "});",
                  "",
                  "pm.test('Content-Type is XML', function () {",
                  "    pm.expect(response.headers['content-type']).to.include('application/xml');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
