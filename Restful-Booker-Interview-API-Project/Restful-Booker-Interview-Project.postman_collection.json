        {
          "name": "POST Create Booking - Positive",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const randomNumber = Math.floor(Math.random() * 10000);",
                  "pm.variables.set('dynamicFirstname', pm.environment.get('firstname') + randomNumber);",
                  "pm.variables.set('dynamicLastname', pm.environment.get('lastname') + randomNumber);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Booking ID is generated', function () {",
                  "    pm.expect(response.bookingid).to.be.a('number');",
                  "});",
                  "",
                  "pm.test('Booking data is created correctly', function () {",
                  "    pm.expect(response.booking.firstname).to.eql(pm.variables.get('dynamicFirstname'));",
                  "    pm.expect(response.booking.lastname).to.eql(pm.variables.get('dynamicLastname'));",
                  "    pm.expect(response.booking.totalprice).to.eql(2500);",
                  "    pm.expect(response.booking.depositpaid).to.eql(true);",
                  "});",
                  "",
                  "const createBookingSchema = {",
                  "    type: 'object',",
                  "    required: ['bookingid', 'booking'],",
                  "    properties: {",
                  "        bookingid: { type: 'number' },",
                  "        booking: {",
                  "            type: 'object',",
                  "            required: ['firstname', 'lastname', 'totalprice', 'depositpaid', 'bookingdates', 'additionalneeds'],",
                  "            properties: {",
                  "                firstname: { type: 'string' },",
                  "                lastname: { type: 'string' },",
                  "                totalprice: { type: 'number' },",
                  "                depositpaid: { type: 'boolean' },",
                  "                bookingdates: {",
                  "                    type: 'object',",
                  "                    required: ['checkin', 'checkout'],",
                  "                    properties: {",
                  "                        checkin: { type: 'string' },",
                  "                        checkout: { type: 'string' }",
                  "                    }",
                  "                },",
                  "                additionalneeds: { type: 'string' }",
                  "            }",
                  "        }",
                  "    }",
                  "};",
                  "",
                  "pm.test('Create booking response schema is valid', function () {",
                  "    pm.response.to.have.jsonSchema(createBookingSchema);",
                  "});",
                  "",
                  "pm.environment.set('bookingId', response.bookingid);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"{{dynamicFirstname}}\",\n  \"lastname\": \"{{dynamicLastname}}\",\n  \"totalprice\": 2500,\n  \"depositpaid\": true,\n  \"bookingdates\": {\n    \"checkin\": \"2026-06-01\",\n    \"checkout\": \"2026-06-05\"\n  },\n  \"additionalneeds\": \"Breakfast\"\n}"
            },
            "url": "{{baseUrl}}/booking"
          },
          "response": []
        },
