                  "pm.test('Booking ID schema is valid when data exists', function () {",
                  "    if (response.length > 0) {",
                  "        pm.expect(response[0]).to.have.property('bookingid');",
                  "        pm.expect(response[0].bookingid).to.be.a('number');",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/booking"
          },
          "response": []
