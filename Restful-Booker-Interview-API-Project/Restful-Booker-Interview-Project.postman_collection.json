    {
      "name": "02 Auth Testing",
      "item": [
        {
          "name": "POST Create Token - Valid Credentials",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Token is generated', function () {",
                  "    pm.expect(response).to.have.property('token');",
                  "    pm.expect(response.token).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.environment.set('token', response.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/auth"
          },
          "response": []
        },
        {
          "name": "POST Create Token - Invalid Credentials",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "pm.test('Demo API returns 200 even for invalid credentials', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Failure reason is returned', function () {",
                  "    pm.expect(response).to.have.property('reason');",
                  "    pm.expect(response.reason).to.eql('Bad credentials');",
                  "});",
                  "",
                  "pm.test('No token is returned for invalid credentials', function () {",
                  "    pm.expect(response).to.not.have.property('token');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"wronguser\",\n  \"password\": \"wrongpassword\"\n}"
            },
            "url": "{{baseUrl}}/auth",
            "description": "Negative authentication test. This demo API returns 200 with reason instead of 401."
          },
          "response": []
        }
      ]
