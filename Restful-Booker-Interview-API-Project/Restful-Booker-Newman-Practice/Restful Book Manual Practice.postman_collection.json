              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"status code is 200 \", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"booking Id is genrated\", function () {\r",
                  "    const response = pm.response.json();\r",
                  "    pm.expect(response).to.have.property(\"bookingid\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Booking Id is stored\", function () {\r",
                  "    const response = pm.response.json();\r",
                  "    pm.environment.set(\"bookingId\", response.bookingid);\r",
                  "    pm.expect(pm.environment.get(\"bookingId\")).to.eql(response.bookingid);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Dynamic firstname is genrated\", function(){\r",
                  "    const response = pm.response.json();\r",
                  "    pm.expect(response.booking.firstname).to.eql(pm.environment.get(\"dynamicFirstname\"));\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Dynamic last name is genrated\", function(){\r",
                  "    const response = pm.response.json();\r",
                  "    pm.expect(response.booking.lastname).to.eql(pm.environment.get(\"dynamicLastname\"));\r",
                  "});"
