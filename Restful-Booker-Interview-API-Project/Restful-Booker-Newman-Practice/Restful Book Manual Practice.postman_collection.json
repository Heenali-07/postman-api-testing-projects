        {
          "name": "GET Booking JSON Schema",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const bookingSchema = {\r",
                  "    type: \"object\",\r",
                  "    required: [\r",
                  "        \"firstname\",\r",
                  "        \"lastname\",\r",
                  "        \"totalprice\",\r",
                  "        \"depositpaid\",\r",
                  "        \"bookingdates\",\r",
                  "        \"additionalneeds\"\r",
                  "    ],\r",
                  "    properties: {\r",
                  "        firstname: {\r",
                  "            type: \"string\"\r",
                  "        },\r",
                  "        lastname: {\r",
                  "            type: \"string\"\r",
                  "        },\r",
                  "        totalprice: {\r",
                  "            type: \"number\"\r",
                  "        },\r",
                  "        depositpaid: {\r",
                  "            type: \"boolean\"\r",
                  "        },\r",
                  "        bookingdates: {\r",
                  "            type: \"object\",\r",
                  "            required: [\r",
                  "                \"checkin\",\r",
                  "                \"checkout\"\r",
                  "            ],\r",
                  "            properties: {\r",
                  "                checkin: {\r",
                  "                    type: \"string\"\r",
                  "                },\r",
                  "                checkout: {\r",
                  "                    type: \"string\"\r",
                  "                }\r",
                  "            }\r",
                  "        },\r",
                  "        additionalneeds: {\r",
                  "            type: \"string\"\r",
                  "        }\r",
                  "    }\r",
                  "};\r",
                  "\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Booking JSON schema is valid\", function () {\r",
                  "    pm.response.to.have.jsonSchema(bookingSchema);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
